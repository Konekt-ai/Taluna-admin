# =====================================================================
#  Taluna Admin — variables de entorno
#  Copia este archivo como ".env.local" y rellena los valores.
#  Las consigues en: app.supabase.com -> tu proyecto -> Settings -> API
#  ⚠️ NUNCA subas .env.local a GitHub (ya está en .gitignore).
# =====================================================================

# --- Públicas (mismas que el sitio público; el navegador puede verlas) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica

# --- SOLO SERVIDOR (secreta). Settings -> API -> "service_role". ---
# Esta llave puede escribir TODO. Jamás la pongas con prefijo NEXT_PUBLIC_
# ni la compartas. Va aquí y en las variables de entorno de Vercel.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-secreta

# --- Opcional: restringe el panel a UN solo correo (el de la dueña). ---
# Si lo dejas vacío, cualquier usuario creado en Supabase Auth podrá entrar.
ADMIN_EMAIL=
